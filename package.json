{
  "name": "claude-compass",
  "version": "1.0.0",
  "description": "Claude Compass is an AI-native decision layer that helps Claude.ai users identify the right capability for their task — before they run it. Includes: intent classification engine · capability recommendation panel · tradeoff preview · workflow execution view · free vs. pro upgrade flow",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
